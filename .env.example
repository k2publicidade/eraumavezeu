# Database (Supabase com Supavisor pooler)
# DATABASE_URL: porta 6543 (pooler transaction mode) — usado em runtime
# DIRECT_URL: porta 5432 (direct connection) — usado só para migrations
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# NextAuth / Auth.js v5
AUTH_SECRET="gerar com: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# Google OAuth (opcional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Mercado Pago
MP_ACCESS_TOKEN=""
MP_WEBHOOK_SECRET=""
MP_PUBLIC_KEY=""

# Melhor Envio
MELHOR_ENVIO_TOKEN=""
CEP_ORIGEM="22000000"

# Resend (email)
RESEND_API_KEY=""
EMAIL_FROM="atendimento@eraumavezeu.com.br"
# E-mail interno que recebe aviso de novo pedido (fallback: CONTACT_EMAIL)
ORDER_NOTIFICATIONS_EMAIL=""

# Evolution API (WhatsApp)
EVOLUTION_API_URL=""
EVOLUTION_API_KEY=""
EVOLUTION_INSTANCE=""

# Uploadthing
UPLOADTHING_TOKEN=""
UPLOADTHING_SECRET=""

# Sentry
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# Cron (Vercel)
CRON_SECRET="gerar com: openssl rand -base64 32"

# App
NEXT_PUBLIC_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Era Uma Vez Eu"
NEXT_PUBLIC_WHATSAPP_NUMBER="5521999999999"

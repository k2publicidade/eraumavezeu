// Era Uma Vez Eu — Prisma Schema
// Supabase Postgres via Supavisor pooler (DATABASE_URL=6543, DIRECT_URL=5432)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// Auth (NextAuth/Auth.js v5 Prisma adapter)
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // bcrypt hash; null quando só OAuth
  role          Role      @default(CUSTOMER)
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  orders   Order[]
}

enum Role {
  CUSTOMER
  ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// Produtos & Catálogo
// ============================================================

model Product {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  description String      @db.Text
  price       Decimal     @db.Decimal(10, 2)
  priceOld    Decimal?    @db.Decimal(10, 2)
  type        ProductType
  active      Boolean     @default(true)
  images      String[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  orderItems OrderItem[]
}

enum ProductType {
  LIVRO_PRINCIPAL
  EBOOK
  LIVRO_COLORIR
  QUEBRA_CABECA
  CARTELA_ADESIVOS
}

// ============================================================
// Pedidos
// ============================================================

model Order {
  id              String        @id @default(cuid())
  userId          String?
  user            User?         @relation(fields: [userId], references: [id])
  guestEmail      String?
  guestName       String?
  guestPhone      String?
  status          OrderStatus   @default(AGUARDANDO_PAGAMENTO)
  shippingMethod  String?
  shippingCost    Decimal       @default(0) @db.Decimal(10, 2)
  subtotal        Decimal       @db.Decimal(10, 2)
  discount        Decimal       @default(0) @db.Decimal(10, 2)
  total           Decimal       @db.Decimal(10, 2)
  paymentMethod   String?
  paymentId       String?       @unique // MP payment id — UNIQUE para idempotência de webhook
  paymentStatus   PaymentStatus @default(PENDENTE)
  paymentGateway  String?       @default("MERCADOPAGO")
  paymentUrl      String?       @db.Text
  pixQrCode       String?       @db.Text
  pixQrCodeBase64 String?       @db.Text
  trackingCode    String?
  dedication      String?       @db.Text
  notes           String?       @db.Text
  whatsappOptIn   Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deliveredAt     DateTime?     // usado pelo cron de retenção LGPD

  items           OrderItem[]
  customization   Customization?
  shippingAddress Address?
  statusHistory   OrderStatusHistory[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

enum OrderStatus {
  AGUARDANDO_PAGAMENTO
  PAGAMENTO_CONFIRMADO
  EM_PRODUCAO
  AGUARDANDO_ENVIO
  ENVIADO
  ENTREGUE
  CANCELADO
}

enum PaymentStatus {
  PENDENTE
  APROVADO
  REJEITADO
  REEMBOLSADO
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
  discount  Decimal @default(0) @db.Decimal(10, 2)

  @@index([orderId])
}

model OrderStatusHistory {
  id         String      @id @default(cuid())
  orderId    String
  order      Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus OrderStatus?
  toStatus   OrderStatus
  changedBy  String?     // userId do admin ou "system"
  changedAt  DateTime    @default(now())
  note       String?     @db.Text

  @@index([orderId])
}

// ============================================================
// Personalização (dados sensíveis — LGPD)
// ============================================================

model Customization {
  id            String   @id @default(cuid())
  orderId       String   @unique
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  childName     String
  theme         String   // dinossauros | floresta_encantada | trem | princesas | robos
  genre         String   // acao | comedia | aventura | misterio | conto_de_fadas
  artStyle      String   // realista | lapiz | computadorizado
  favoriteColor String
  ageRange      String   // 0-3 | 4-6 | 7-10
  photoKeys     String[] // fileKeys do Uploadthing — bucket privado; URL se constrói via signed URL
  dedication    String?  @db.Text
  aiPrompt      String?  @db.Text

  // LGPD Art. 14 — registro de consentimento
  consentIp          String
  consentAt          DateTime
  consentTextVersion String   // versão do texto do termo aceito
  photosExpireAt     DateTime? // preenchido quando order muda para ENTREGUE (now + 90 dias)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([photosExpireAt])
}

// ============================================================
// Endereço de entrega
// ============================================================

model Address {
  id         String  @id @default(cuid())
  orderId    String  @unique
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  name       String
  street     String
  number     String
  complement String?
  district   String
  city       String
  state      String
  zipCode    String
  country    String  @default("BR")
}

// ============================================================
// Conteúdo editável do site
// ============================================================

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  label     String
  type      String   @default("text")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

model FaqItem {
  id        String   @id @default(cuid())
  question  String
  answer    String   @db.Text
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, sortOrder])
}

// ============================================================
// Mensagens de Contato (Fale Conosco)
// ============================================================

model ContactMessage {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String        @db.Text
  status    ContactStatus @default(NOVA)
  notes     String?       @db.Text
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
}

enum ContactStatus {
  NOVA
  LIDA
  RESPONDIDA
  ARQUIVADA
}

